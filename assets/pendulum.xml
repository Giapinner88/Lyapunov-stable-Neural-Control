<mujoco model="pendulum_phase_space">
    <option timestep="0.005" integrator="RK4" gravity="0 0 -9.81"/>
    
    <worldbody>
        <light pos="0 -2 3" dir="0 1 -1" directional="true" castshadow="true"/>
        <geom name="floor" type="plane" size="2 2 0.1" rgba="0.8 0.9 0.8 1" contype="1" conaffinity="1"/>
        <camera name="cam_side" pos="0 -3 1.0" quat="0.7071 0.7071 0 0"/>
        
        <body name="pivot" pos="0 0 1.0">
            <geom type="cylinder" size="0.05 0.1" rgba="0.1 0.1 0.9 1" quat="0.7071 0.7071 0 0"/>
            <body name="pendulum_link" pos="0 0 0">
                <joint name="hinge_y" type="hinge" axis="0 1 0" pos="0 0 0" damping="0.1"/>
                <inertial pos="0 0 -0.5" mass="0.15" diaginertia="0.0375 0.0375 0.0375"/>
                <geom type="cylinder" fromto="0 0 0  0 0 -0.5" size="0.01" rgba="0.5 0.5 0.5 1" contype="0" conaffinity="0"/>
                <geom type="sphere" pos="0 0 -0.5" size="0.05" rgba="0.8 0.2 0.2 1"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="torque_motor" joint="hinge_y" gear="1" ctrllimited="true" ctrlrange="-1.0 1.0"/>
    </actuator>

    <sensor>
        <jointpos joint="hinge_y" name="sens_theta"/>
        <jointvel joint="hinge_y" name="sens_theta_dot"/>
    </sensor>
</mujoco>