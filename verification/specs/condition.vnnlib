; Khai báo biến đầu vào X (Trạng thái)
(declare-const X_0 Real)
(declare-const X_1 Real)

; Khai báo biến đầu ra Y
(declare-const Y_0 Real)
(declare-const Y_1 Real)

; Giới hạn vật lý của trạng thái (Preconditions)
(assert (>= X_0 -3.1415927410125732))
(assert (<= X_0 3.1415927410125732))
(assert (>= X_1 -8.0))
(assert (<= X_1 8.0))

; Điều kiện Vi phạm (Postconditions / Target)
(assert (<= Y_1 0.037500000000000006))
(assert (>= Y_0 0.0))
